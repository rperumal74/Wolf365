# =============================================================================
# Wolf365 environment configuration
#
# Copy to .env.local for local development. In production these are configured
# as Vercel Environment Variables. NEVER commit real secrets.
#
# Connector credentials (TD SYNNEX, QuickBooks, Hudu, SuperOps) are NOT stored
# here. They are entered by an admin in the app and encrypted at rest in the
# database using WOLF365_ENCRYPTION_KEY.
# =============================================================================

# --- Database (Neon Postgres) ------------------------------------------------
# Pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Direct (non-pooled) connection string used by Prisma Migrate.
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# --- Application encryption key ----------------------------------------------
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this key makes existing encrypted secrets unreadable. Plan rotation.
WOLF365_ENCRYPTION_KEY=""

# --- Auth.js (NextAuth) ------------------------------------------------------
# Secret used to sign/encrypt session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
# Canonical app URL (used for OAuth redirect URIs). e.g. https://wolf365.example.com
AUTH_URL="http://localhost:3000"

# --- Bootstrap admin ---------------------------------------------------------
# Email addresses (comma-separated) granted OWNER role on first login, so the
# very first sign-in can configure SSO and connectors. Optional once seeded.
WOLF365_BOOTSTRAP_ADMINS=""

# --- First-run Entra SSO bootstrap (optional) --------------------------------
# Used ONLY until SSO is configured in-app (Security & SSO page). Lets the
# bootstrap admin sign in to set up SSO. After that, manage SSO in the app.
ENTRA_TENANT_ID=""
ENTRA_CLIENT_ID=""
ENTRA_CLIENT_SECRET=""

# --- Vercel Cron -------------------------------------------------------------
# Shared secret Vercel injects as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=""
# Debug-log retention window in days (30-90 typical).
WOLF365_DEBUG_LOG_RETENTION_DAYS="30"

# --- Runtime -----------------------------------------------------------------
NODE_ENV="development"
